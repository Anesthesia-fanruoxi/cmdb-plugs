# Elasticsearch 配置
ES_HOST=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=your-password

# 日志配置
# 日志级别: info 或 error
# info - 输出所有日志（包括 info 和 error）
# error - 只输出错误日志
LOG_LEVEL=info

# 限制配置
# ES返回最大条数限制（默认3000，最大不能超过3000）
# 即使设置为5000，实际也会被限制为3000
LIMIT_MAX_SIZE=3000

# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改对应的值
# 3. 在启动前 source .env (Linux/Mac) 或使用 docker-compose
